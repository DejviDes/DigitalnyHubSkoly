{
  "version": 2,
  "routes": [
    {
      "src": "^/api/contact$",
      "dest": "/api/contact.js"
    },
    {
      "src": "^/pages/ako-to-funguje\.html$",
      "status": 308,
      "headers": {
        "Location": "/pages/riesenie.html#ako-to-funguje"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/.*$",
      "status": 404,
      "dest": "/404.html"
    }
  ]
}
